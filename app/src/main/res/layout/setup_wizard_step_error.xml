<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/ln_installing_packages_failed"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/setup_wizard_screen_padding"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_error_large"
            style="@style/Widget.Vectras.SetupWizard.HeaderIcon"
            android:src="@drawable/error_96px"
            android:contentDescription="@null"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/tv_error_title"
            style="@style/TextAppearance.Vectras.SetupWizard.Title"
            android:text="@string/something_went_wrong" />

        <TextView
            android:id="@+id/tv_error_subtitle"
            style="@style/TextAppearance.Vectras.SetupWizard.Body"
            android:text="@string/the_setup_could_not_be_completed_and_below_is_the_log" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cd_install_status"
            style="@style/Widget.Vectras.SetupWizard.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/setup_wizard_content_padding_small">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/setup_wizard_card_padding">

                <TextView
                    style="@style/TextAppearance.Vectras.SetupWizard.Caption"
                    android:text="@string/setup_status_current_step_label" />

                <TextView
                    android:id="@+id/tv_install_current_step"
                    style="@style/TextAppearance.Vectras.SetupWizard.Body"
                    android:text="@string/setup_status_unknown"
                    app:fontFamily="@font/googlesansvodevariablefontwght" />

                <TextView
                    style="@style/TextAppearance.Vectras.SetupWizard.Caption"
                    android:layout_marginTop="@dimen/setup_wizard_content_padding_small"
                    android:text="@string/setup_status_last_error_label" />

                <TextView
                    android:id="@+id/tv_install_last_error"
                    style="@style/TextAppearance.Vectras.SetupWizard.Body"
                    android:text="@string/setup_status_no_error"
                    app:fontFamily="@font/googlesansvodevariablefontwght" />

                <TextView
                    style="@style/TextAppearance.Vectras.SetupWizard.Caption"
                    android:layout_marginTop="@dimen/setup_wizard_content_padding_small"
                    android:text="@string/setup_status_recommended_action_label" />

                <TextView
                    android:id="@+id/tv_install_recommended_action"
                    style="@style/TextAppearance.Vectras.SetupWizard.Body"
                    android:text="@string/setup_action_retry"
                    app:fontFamily="@font/googlesansvodevariablefontwght" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Vectras.SetupWizard.Card"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/setup_wizard_section_spacing"
            android:layout_weight="1">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/tv_error_log_content"
                    style="@style/TextAppearance.Vectras.SetupWizard.Body"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/setup_wizard_content_padding_small"
                    android:textIsSelectable="true"
                    app:fontFamily="@font/googlesansvodevariablefontwght" />
            </androidx.core.widget.NestedScrollView>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/ln_try_again_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/setup_wizard_section_spacing"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_export_diagnostic"
                style="@style/Widget.Vectras.SetupWizard.Button.Tertiary"
                android:layout_marginEnd="@dimen/setup_wizard_content_padding_small"
                android:text="@string/setup_action_export_diagnostic" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_rollback_setup"
                style="@style/Widget.Vectras.SetupWizard.Button.Secondary"
                android:layout_marginEnd="@dimen/setup_wizard_content_padding_small"
                android:text="@string/setup_action_rollback" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_retry_setup"
                style="@style/Widget.Vectras.SetupWizard.Button.Primary"
                android:text="@string/setup_action_retry" />
        </LinearLayout>
    </LinearLayout>
</merge>
