<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/ln_getting_data"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/setup_wizard_screen_padding"
        android:visibility="gone">

        <ImageView
            style="@style/Widget.Vectras.SetupWizard.HeaderIcon"
            android:src="@drawable/android_wifi_3_bar_100px"
            android:contentDescription="@null"
            android:importantForAccessibility="no" />

        <TextView
            style="@style/TextAppearance.Vectras.SetupWizard.Title"
            android:text="@string/connecting" />

        <TextView
            style="@style/TextAppearance.Vectras.SetupWizard.Body"
            android:text="@string/just_a_sec" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/lpi_getting_data"
            style="@style/Widget.Vectras.SetupWizard.ProgressIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/setup_wizard_section_spacing"
            android:indeterminate="true"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/ln_getting_data_cpi_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/cpi_getting_data"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                app:indicatorSize="@dimen/setup_wizard_progress_circular_size" />
        </LinearLayout>
    </LinearLayout>
</merge>
