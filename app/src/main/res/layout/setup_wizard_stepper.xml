<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/setup_wizard_screen_padding"
        android:paddingTop="@dimen/setup_wizard_screen_padding"
        android:paddingEnd="@dimen/setup_wizard_screen_padding"
        android:paddingBottom="@dimen/setup_wizard_content_padding_small">

        <TextView
            android:id="@+id/tv_step_status"
            style="@style/TextAppearance.Vectras.SetupWizard.StepStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_step_status_default" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/wizard_step_progress"
            style="@style/Widget.Vectras.SetupWizard.ProgressIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/setup_wizard_content_padding_small"
            android:max="5"
            android:progress="0"
            android:contentDescription="@string/setup_stepper_progress_content_description" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/setup_wizard_content_padding_small"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_step_1"
                style="@style/Widget.Vectras.SetupWizard.StepBadge"
                android:text="1" />

            <TextView
                android:id="@+id/tv_step_2"
                style="@style/Widget.Vectras.SetupWizard.StepBadge"
                android:layout_marginStart="@dimen/setup_wizard_step_badge_spacing"
                android:text="2" />

            <TextView
                android:id="@+id/tv_step_3"
                style="@style/Widget.Vectras.SetupWizard.StepBadge"
                android:layout_marginStart="@dimen/setup_wizard_step_badge_spacing"
                android:text="3" />

            <TextView
                android:id="@+id/tv_step_4"
                style="@style/Widget.Vectras.SetupWizard.StepBadge"
                android:layout_marginStart="@dimen/setup_wizard_step_badge_spacing"
                android:text="4" />

            <TextView
                android:id="@+id/tv_step_5"
                style="@style/Widget.Vectras.SetupWizard.StepBadge"
                android:layout_marginStart="@dimen/setup_wizard_step_badge_spacing"
                android:text="5" />
        </LinearLayout>
    </LinearLayout>
</merge>
